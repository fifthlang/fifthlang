{
  "name": "fifth",
  "scopeName": "source.fifth",
  "fileTypes": ["5th", "fifth"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#sparql-literal" },
    { "include": "#trig-literal" },
    { "include": "#triple-literal" },
    { "include": "#iri-reference" },
    { "include": "#alias-declaration" },
    { "include": "#store-declaration" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#rune-literal" },
    { "include": "#function-declaration" },
    { "include": "#class-declaration" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fifth",
          "match": "//.*$"
        },
        {
          "name": "comment.block.fifth",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.fifth",
          "begin": "\\$\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.fifth",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.fifth",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.fifth" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.fifth" }
              },
              "patterns": [
                { "include": "source.fifth" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.double.fifth",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.fifth",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.raw.fifth",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "sparql-literal": {
      "name": "meta.sparql-literal.fifth",
      "begin": "(\\?<)",
      "end": "(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.sparql.begin.fifth" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.sparql.end.fifth" }
      },
      "patterns": [
        {
          "name": "string.unquoted.sparql.fifth",
          "match": "[^>]+"
        }
      ]
    },
    "trig-literal": {
      "name": "meta.trig-literal.fifth",
      "begin": "(@<)",
      "end": "(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.trig.begin.fifth" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.trig.end.fifth" }
      },
      "patterns": [
        {
          "name": "meta.interpolation.trig.fifth",
          "begin": "\\{\\{",
          "end": "\\}\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.fifth" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.fifth" }
          },
          "patterns": [
            { "include": "source.fifth" }
          ]
        },
        {
          "name": "string.unquoted.trig.fifth",
          "match": "[^>{}]+"
        }
      ]
    },
    "triple-literal": {
      "name": "meta.triple.fifth",
      "begin": "(<)(?=[^<>]*,)",
      "end": "(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.triple.begin.fifth" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.triple.end.fifth" }
      },
      "patterns": [
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#iri-prefix" },
        {
          "name": "punctuation.separator.triple.fifth",
          "match": ","
        }
      ]
    },
    "iri-reference": {
      "name": "string.other.iri.fifth",
      "match": "<[a-zA-Z][a-zA-Z0-9+.-]*://[^>]+>"
    },
    "iri-prefix": {
      "name": "entity.name.namespace.fifth",
      "match": "[a-zA-Z_][a-zA-Z0-9_]*:[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "alias-declaration": {
      "match": "\\b(alias)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(as)\\b",
      "captures": {
        "1": { "name": "keyword.other.alias.fifth" },
        "2": { "name": "entity.name.namespace.fifth" },
        "3": { "name": "keyword.other.as.fifth" }
      }
    },
    "store-declaration": {
      "match": "\\b(sparql_store)\\s*\\(",
      "captures": {
        "1": { "name": "support.function.store.fifth" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fifth",
          "match": "\\b(if|else|while|for|return|break|continue|switch|case|default|fallthrough|try|catch|finally|throw|goto|defer|select|with|range)\\b"
        },
        {
          "name": "keyword.other.fifth",
          "match": "\\b(use|alias|as|import|export|from|where|in|new|namespace|package|var|const|type)\\b"
        },
        {
          "name": "keyword.declaration.fifth",
          "match": "\\b(func|fun|class|struct|interface|extends)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.fifth",
          "match": "\\b(int|float|string|bool|rune|graph|triple|store|query|result)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.fifth",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.compound.fifth",
          "match": "\\+=|-=|:="
        },
        {
          "name": "keyword.operator.arrow.fifth",
          "match": "->|<-"
        },
        {
          "name": "keyword.operator.arithmetic.fifth",
          "match": "\\*\\*|\\+\\+|--|<<|>>|<>"
        },
        {
          "name": "keyword.operator.comparison.fifth",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.fifth",
          "match": "&&|\\|\\||!&|!\\||!|~"
        },
        {
          "name": "keyword.operator.arithmetic.fifth",
          "match": "[+\\-*/%^&|]"
        },
        {
          "name": "keyword.operator.assignment.fifth",
          "match": "="
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex-float.fifth",
          "match": "0[xX][0-9a-fA-F_]*\\.[0-9a-fA-F_]*[pP][+-]?[0-9_]+"
        },
        {
          "name": "constant.numeric.hex.fifth",
          "match": "0[xX][0-9a-fA-F_]+"
        },
        {
          "name": "constant.numeric.binary.fifth",
          "match": "0[bB][01_]+"
        },
        {
          "name": "constant.numeric.octal.fifth",
          "match": "0[oO][0-7_]+"
        },
        {
          "name": "constant.numeric.float.fifth",
          "match": "[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?[fFdDmM]?"
        },
        {
          "name": "constant.numeric.float.fifth",
          "match": "\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?[fFdDmM]?"
        },
        {
          "name": "constant.numeric.float.fifth",
          "match": "[0-9][0-9_]*[eE][+-]?[0-9_]+[fFdDmM]?"
        },
        {
          "name": "constant.numeric.float.fifth",
          "match": "[0-9][0-9_]*[fFdDmM]"
        },
        {
          "name": "constant.numeric.imaginary.fifth",
          "match": "[0-9][0-9_]*i\\b"
        },
        {
          "name": "constant.numeric.integer.fifth",
          "match": "[0-9][0-9_]*"
        }
      ]
    },
    "rune-literal": {
      "name": "string.quoted.single.fifth",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.fifth",
          "match": "\\\\(u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8}|[abfnrtv\\\\'\"]|[0-7]{3}|x[0-9a-fA-F]{2})"
        }
      ]
    },
    "function-declaration": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(<[^>]*>)?\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.fifth" },
        "2": { "name": "meta.type-parameters.fifth" }
      }
    },
    "class-declaration": {
      "match": "\\b(class|struct|interface)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.fifth" },
        "2": { "name": "entity.name.type.class.fifth" }
      }
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.fifth",
          "match": "[;,]"
        },
        {
          "name": "punctuation.accessor.fifth",
          "match": "\\."
        },
        {
          "name": "punctuation.section.braces.begin.fifth",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.fifth",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.fifth",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.fifth",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.fifth",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.fifth",
          "match": "\\]"
        }
      ]
    }
  }
}
