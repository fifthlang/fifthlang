---
/**
 * [...slug].astro — Dynamic documentation page route.
 *
 * Queries the docs content collection and renders each entry
 * using DocLayout with getStaticPaths.
 * Heading anchor IDs are generated by rehype-slug.
 *
 * Validates: Requirements 4.1, 4.4
 */

import { getCollection } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<DocLayout title={entry.data.title} description={entry.data.description}>
  <Content />
</DocLayout>
