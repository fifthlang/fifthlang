---
/**
 * tutorials/[...slug].astro — Dynamic tutorial page route.
 *
 * Queries the tutorials content collection and renders each entry
 * using TutorialLayout with getStaticPaths.
 *
 * Validates: Requirements 5.1, 5.2
 */

import { getCollection } from 'astro:content';
import TutorialLayout from '../../layouts/TutorialLayout.astro';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Resolve next tutorial title if nextTutorial slug is set
let nextTutorialTitle: string | undefined;
if (entry.data.nextTutorial) {
  const tutorials = await getCollection('tutorials');
  const next = tutorials.find((t) => t.slug === entry.data.nextTutorial);
  nextTutorialTitle = next?.data.title;
}
---

<TutorialLayout
  title={entry.data.title}
  readingTime={entry.data.readingTime}
  prerequisites={entry.data.prerequisites}
  nextTutorial={entry.data.nextTutorial}
  nextTutorialTitle={nextTutorialTitle}
>
  <Content />
</TutorialLayout>
