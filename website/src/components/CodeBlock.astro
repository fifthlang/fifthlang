---
/**
 * CodeBlock.astro — Enhanced code block wrapper.
 *
 * Wraps code blocks with a copy-to-clipboard button.
 * For blocks exceeding 20 lines: adds visible line numbers and a scrollable container.
 *
 * Usage:
 *   <CodeBlock code="const x = 1;" lang="typescript" />
 *
 * Validates: Requirements 3.4, 8.2, 8.3
 */

interface Props {
  code: string;
  lang?: string;
}

const { code, lang = '' } = Astro.props;

const lines = code.split('\n');
// Remove trailing empty line that often appears from template literals
const trimmedLines = lines.at(-1) === '' ? lines.slice(0, -1) : lines;
const lineCount = trimmedLines.length;
const isLong = lineCount > 20;
---

<div class:list={['code-block-wrapper', { 'code-block-long': isLong }]}>
  <div class="code-block-header">
    {lang && <span class="code-block-lang">{lang}</span>}
    <button
      type="button"
      class="code-block-copy"
      aria-label="Copy code to clipboard"
      data-code={code}
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
      <span class="code-block-copy-label">Copy</span>
    </button>
  </div>

  <div class="code-block-body">
    {isLong && (
      <div class="code-block-line-numbers" aria-hidden="true">
        {trimmedLines.map((_, i) => (
          <span class="line-number">{i + 1}</span>
        ))}
      </div>
    )}
    <pre class="code-block-pre"><code class={lang ? `language-${lang}` : ''}>{code}</code></pre>
  </div>
</div>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.code-block-copy');
    if (!btn) return;

    const code = btn.getAttribute('data-code');
    if (!code) return;

    const label = btn.querySelector('.code-block-copy-label');

    navigator.clipboard.writeText(code).then(() => {
      if (label) {
        label.textContent = 'Copied!';
        setTimeout(() => {
          label.textContent = 'Copy';
        }, 2000);
      }
    }).catch(() => {
      if (label) {
        label.textContent = 'Failed';
        setTimeout(() => {
          label.textContent = 'Copy';
        }, 2000);
      }
    });
  });
</script>

<style>
  .code-block-wrapper {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background-color: var(--color-bg-code);
    margin-bottom: var(--space-4);
    overflow: hidden;
  }

  .code-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg-secondary);
  }

  .code-block-lang {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    text-transform: lowercase;
  }

  .code-block-copy {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    font-family: var(--font-sans);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .code-block-copy:hover {
    color: var(--color-text-primary);
    background-color: var(--color-bg-code);
  }

  .code-block-copy:focus-visible {
    outline: 2px solid var(--color-accent-magenta);
    outline-offset: 2px;
  }

  .code-block-body {
    display: flex;
  }

  /* Long code blocks: scrollable container */
  .code-block-long .code-block-body {
    max-height: 32rem;
    overflow-y: auto;
  }

  /* Line numbers for long blocks */
  .code-block-line-numbers {
    display: flex;
    flex-direction: column;
    padding: var(--space-4) 0;
    padding-left: var(--space-3);
    padding-right: var(--space-3);
    text-align: right;
    user-select: none;
    border-right: 1px solid var(--color-border);
    background-color: var(--color-bg-secondary);
    flex-shrink: 0;
  }

  .line-number {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .code-block-pre {
    margin: 0;
    padding: var(--space-4);
    border: none;
    border-radius: 0;
    background: none;
    overflow-x: auto;
    flex: 1;
    min-width: 0;
  }

  .code-block-pre code {
    background: none;
    padding: 0;
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }
</style>
