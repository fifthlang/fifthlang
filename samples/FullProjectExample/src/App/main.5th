// App: demonstrates cross-project function calls
// square is defined in CoreLib, add is defined in MathLib
main(): int {
    sq: int;
    sq = square(7);
    result: int;
    result = add(sq, 3);
    std.print($"square(7) = {sq}");
    std.print($"add(49, 3) = {result}");
    return 0;
}
