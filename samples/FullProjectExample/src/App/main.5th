// App: demonstrates cross-project function calls
// square is defined in CoreLib, add is defined in MathLib
main(): int {
    sq: int;
    sq = square(7);
    result: int;
    result = add(sq, 3);
    std.print(string.Format("square(7) = {0}", sq));
    std.print(string.Format("add(49, 3) = {0}", result));
    return 0;
}
